/* Scaffold generated once when the zephlet is created.                    */
/* Delete the TODO markers as you flesh out the implementation.             */

#include "{{ zephlet_name }}.h"

#include <errno.h>
#include <zephyr/kernel.h>
#include <zephyr/logging/log.h>

LOG_MODULE_DECLARE({{ zephlet_name }}, CONFIG_ZEPHLET_{{ base_name_upper }}_LOG_LEVEL);

/*
 * Implementation notes
 * --------------------
 *
 * Standard lifecycle RPCs (start/stop/get_status/update_settings/
 * get_settings/get_events) are dispatched directly from the generated
 * api_handler. To attach side effects, provide a strong override for
 * any of the weak hooks declared in {{ zephlet_name }}_interface.h:
 *
 *   {{ zephlet_name }}_pre_start   / {{ zephlet_name }}_post_start
 *   {{ zephlet_name }}_pre_stop    / {{ zephlet_name }}_post_stop
{%- if has_settings %}
 *   {{ zephlet_name }}_validate_settings
 *   {{ zephlet_name }}_post_update_settings
{%- endif %}
 *
 * Access mutable state through the internal helpers in {{ zephlet_name }}.h:
 *
 *   struct zephlet_status {{ base_name }}_status_clone(void);
{%- if has_settings %}
 *   struct {{ settings_type }} {{ base_name }}_settings_clone(void);
 *   void {{ base_name }}_settings_init(const struct {{ settings_type }} *defaults);
{%- endif %}
{%- if has_events %}
 *   struct {{ events_type }} {{ base_name }}_events_clone(void);
 *   int {{ base_name }}_events_update(struct {{ zephlet_name }}_context *ctx,
 *                                      const struct {{ events_type }} *delta);
 *     ctx = NULL for ISR/fire-and-forget (K_NO_WAIT), non-NULL for
 *     deadline-aware publish. Differential merge: only has_<field>-
 *     flagged fields are updated. timestamp is auto-set.
{%- endif %}
 */

{%- for method in custom_rpc_methods %}
{%- if not method.output_streaming %}

static int {{ method.name }}(struct {{ zephlet_name }}_context *ctx
{%- if method.input_type != 'Empty' and not method.input_type.endswith('.Empty') -%}
{%- if method.input_is_enum -%}
, enum {{ pb_prefix }}_{{ method.input_type|proto_type_to_snake }} {{ method.input_type|proto_type_to_snake }}
{%- else -%}
, const struct {{ pb_prefix }}_{{ method.input_type|proto_type_to_snake }} *{{ method.input_type|proto_type_to_snake }}
{%- endif -%}
{%- endif -%})
{
	ARG_UNUSED(ctx);
{%- if method.input_type != 'Empty' and not method.input_type.endswith('.Empty') %}
	ARG_UNUSED({{ method.input_type|proto_type_to_snake }});
{%- endif %}

	/* TODO: implement {{ method.name }} */
	return 0;
}
{%- endif %}
{%- endfor %}

{%- if custom_invoke_fields %}

static struct {{ zephlet_name }}_api api = {
{%- for field in custom_invoke_fields %}
	.{{ field.name }} = {{ field.name }},
{%- endfor %}
};
{%- endif %}

int {{ zephlet_name }}_init_fn(const struct zephlet *self)
{
{%- if has_settings %}
	/* TODO: seed non-zero Settings defaults here. Example:
	 *   struct {{ settings_type }} defaults = { .has_<field> = true, .<field> = <value> };
	 *   {{ base_name }}_settings_init(&defaults);
	 */
{%- endif %}

	int err = {{ zephlet_name }}_set_implementation(self);
	printk("   -> %s %sinitialized\n", self->name, err == 0 ? "" : "not ");
	return err;
}

{% if custom_invoke_fields -%}
ZEPHLET_DEFINE({{ zephlet_name }}, {{ zephlet_name }}_init_fn, &api);
{%- else -%}
ZEPHLET_DEFINE({{ zephlet_name }}, {{ zephlet_name }}_init_fn, NULL);
{%- endif %}
