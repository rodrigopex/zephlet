syntax = "proto3";

import "nanopb.proto";
import "zephlet.proto";

option (nanopb_fileopt).long_names = false;

message {{ zephlet_name_pascal }} {
  /* Runtime config, mutated via the `config` command. Fields you want
   * to keep immutable once set should instead live on the compile-time
   * instance config (the `_cfg` arg of ZEPHLET_NEW). */
  message Config {
    /* TODO: Add config fields. Examples:
     *   uint32 period_ms = 1;
     *   uint32 threshold = 2;
     */
  }

  /* Values published on the async events channel. Consumers receive a
   * full copy of this struct per emit. */
  message Events {
    int32 timestamp = 1;
    /* TODO: Add event fields. */
  }
}

/*
 * Service is informational to nanopb (no code is generated from it);
 * the zephlet v0.3 codegen parses this block to allocate method ids in
 * declaration order starting at 1 (0 is reserved). Service name must
 * not collide with the message name above.
 */
service {{ zephlet_name_pascal }}Api {
  rpc start      (Empty)                             returns (Lifecycle.Status);
  rpc stop       (Empty)                             returns (Lifecycle.Status);
  rpc get_status (Empty)                             returns (Lifecycle.Status);
  rpc config     ({{ zephlet_name_pascal }}.Config)  returns ({{ zephlet_name_pascal }}.Config);
  rpc get_config (Empty)                             returns ({{ zephlet_name_pascal }}.Config);

  /* TODO: Add custom rpc methods below. Each gets a distinct method_id
   *       allocated in declaration order. Keep inputs/outputs to Empty
   *       or one of the nested messages; streaming is not supported. */
}
