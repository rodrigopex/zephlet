syntax = "proto3";

import "nanopb.proto";
import "zephlet.proto";

option (nanopb_fileopt).anonymous_oneof = true;
option (nanopb_fileopt).long_names = false;

message {{ zephlet_name_pascal }} {
  /* RPC-mutable runtime settings. Every field MUST be `optional` so the
   * generated update_settings merge can use nanopb has_<field> flags. */
  message Settings {
    /* TODO: Add settings fields specific to {{ zephlet_name }}. Example:
     *   optional uint32 some_param = 1;
     */
  }

  message Events {
    int32 timestamp = 1;
    /* TODO: Add event fields specific to {{ zephlet_name }} */
  }
}

service {{ zephlet_name_pascal }} {
  option (zephlet.extends_base) = true; /* Extends base zlet */
  /* Custom RPCs below (base lifecycle RPCs are auto-generated) */
}
