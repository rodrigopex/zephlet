/*
 * Default strong handlers
 * -----------------------
 *
 * The generator emits `__weak int {{ zephlet_name_lower }}_<cmd>_impl(...)`
 * stubs returning -ENOSYS. The overrides below satisfy the framework-
 * standard fields (`is_running`, `is_ready`) out of the box so
 * `west zephlet new` produces a scaffold that passes its own tests.
 *
 * Replace the `TODO: side effects` comments with your zephlet's actual
 * work. Delete any override to fall back to -ENOSYS if a method should
 * not be implemented.
 */

int {{ zephlet_name_lower }}_start_impl(const struct zephlet *z, struct lifecycle_status *resp)
{
	struct {{ zephlet_name_lower }}_data *d = z->data;

	if (!d->is_ready) {
		return -ENODEV;
	}
	if (d->is_running) {
		return -EALREADY;
	}

	/* TODO: side effects (start timers, enable hardware, ...). */
	d->is_running = true;

	if (resp != NULL) {
		resp->is_running = true;
		resp->is_ready = true;
	}
	return 0;
}

int {{ zephlet_name_lower }}_stop_impl(const struct zephlet *z, struct lifecycle_status *resp)
{
	struct {{ zephlet_name_lower }}_data *d = z->data;

	if (!d->is_running) {
		return -EALREADY;
	}

	/* TODO: side effects (stop timers, disable hardware, ...). */
	d->is_running = false;

	if (resp != NULL) {
		resp->is_running = false;
		resp->is_ready = d->is_ready;
	}
	return 0;
}

int {{ zephlet_name_lower }}_get_status_impl(const struct zephlet *z, struct lifecycle_status *resp)
{
	struct {{ zephlet_name_lower }}_data *d = z->data;

	if (resp != NULL) {
		resp->is_running = d->is_running;
		resp->is_ready = d->is_ready;
	}
	return 0;
}

int {{ zephlet_name_lower }}_config_impl(const struct zephlet *z,
					 const struct {{ zephlet_name_lower }}_config *req,
					 struct {{ zephlet_name_lower }}_config *resp)
{
	struct {{ zephlet_name_lower }}_config *cfg = z->config;

	/* TODO: validate req (reject invalid combinations with -EINVAL). */

	*cfg = *req;

	/* TODO: apply config changes if `((struct {{ zephlet_name_lower }}_data *)z->data)->is_running`. */

	if (resp != NULL) {
		*resp = *cfg;
	}
	return 0;
}

int {{ zephlet_name_lower }}_get_config_impl(const struct zephlet *z,
					     struct {{ zephlet_name_lower }}_config *resp)
{
	struct {{ zephlet_name_lower }}_config *cfg = z->config;

	if (resp != NULL) {
		*resp = *cfg;
	}
	return 0;
}

int {{ zephlet_name_lower }}_init_fn(const struct zephlet *z)
{
	struct {{ zephlet_name_lower }}_data *d = z->data;

	d->is_running = false;
	d->is_ready = true;

	LOG_INF("%s: init", z->name);
	return 0;
}

