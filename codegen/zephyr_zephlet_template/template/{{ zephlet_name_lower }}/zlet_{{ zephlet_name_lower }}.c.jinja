int zlet_{{ zephlet_name_lower }}_init_fn(const struct zephlet *self)
{
	int ret;

	/* Initialize zephlet resources */
	ret = zlet_{{ zephlet_name_lower }}_init(self);

	/* Register implementation */
	if (ret == 0) {
		ret = zlet_{{ zephlet_name_lower }}_set_implementation(self);
	}

	printk("   -> %s %sinitialized\n", self->name, ret == 0 ? "" : "not ");

	return ret;
}

